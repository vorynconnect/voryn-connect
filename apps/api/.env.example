# Voryn Connect API — environment template. Copy to .env and fill in values.
# Never commit real secrets.

NODE_ENV=development
PORT=4100

# PostgreSQL (docker-compose exposes 5433 on the host)
DATABASE_URL=postgresql://voryn:voryn_dev_password@localhost:5433/voryn_connect?schema=public

# Redis (docker-compose exposes 6380 on the host)
REDIS_URL=redis://localhost:6380

# Auth — generate long random strings for production
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# OTP (dev mode logs codes instead of sending SMS/email)
OTP_DEV_MODE=true
OTP_TTL_MINUTES=10

# CORS — comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:4173

# Team console bootstrap (optional): when both are set and no user exists with
# that email, an ADMIN account is created on boot. Dev alternative:
# `npm run seed:admin` creates admin@voryn.dev / AdminDev1!.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# Media uploads. 'local' = disk under MEDIA_UPLOAD_DIR (needs a persistent
# volume in production). 's3' = any S3-compatible object store (recommended for
# hosts with ephemeral disks); requires the S3_* + MEDIA_PUBLIC_BASE_URL vars.
MEDIA_STORAGE=local
MEDIA_UPLOAD_DIR=uploads
MEDIA_MAX_SIZE_MB=8

# Object storage (used when MEDIA_STORAGE=s3). Works with AWS S3, Cloudflare R2,
# Backblaze B2, DigitalOcean Spaces, or MinIO.
S3_ENDPOINT=                       # leave blank for AWS; set for R2/B2/Spaces/MinIO
S3_REGION=auto                     # e.g. 'auto' (R2), 'us-east-1' (AWS)
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false          # true for MinIO and some providers
MEDIA_PUBLIC_BASE_URL=             # public URL objects are served from (bucket public URL or CDN)

# Payment gateway (sandbox) — leave blank in dev, wallet + mock card flows work without it
CARD_GATEWAY_API_KEY=
CARD_GATEWAY_WEBHOOK_SECRET=

# Dev fulfillment simulator — set false when testing the partner dashboard
SIMULATE_FULFILLMENT=true

# Map provider (OSM-compatible defaults; swap for keyed/self-hosted services in production)
MAPS_GEOCODER_URL=https://nominatim.openstreetmap.org
MAPS_ROUTER_URL=https://router.project-osrm.org
# Optional API keys for keyed OSM-compatible providers (LocationIQ, Geoapify).
# Leave blank to use the public demo servers (development only).
MAPS_GEOCODER_KEY=
MAPS_ROUTER_KEY=
# Log a warning when daily provider calls cross this threshold
MAPS_DAILY_CALL_WARNING=5000
# Platform-wide delivery radius (km) — drop-offs beyond this are out of zone
DELIVERY_MAX_KM=15
# Ride fare quotes stay bookable for this many minutes
RIDE_QUOTE_TTL_MINUTES=10

# Driver search staging: expanding radii (km), seconds per stage, and the total
# window before an honest "no drivers available" result.
RIDE_SEARCH_RADII_KM=1.5,3,5,8,12
RIDE_SEARCH_STAGE_SECONDS=25
RIDE_SEARCH_MAX_SECONDS=240
# Presence freshness (seconds): markers may show slightly older fixes than dispatch trusts
DRIVER_PRESENCE_MARKER_FRESH_SECONDS=60
DRIVER_PRESENCE_DISPATCH_FRESH_SECONDS=30
# Couriers with a fresh GPS fix only see deliveries whose pickup is this close (km)
COURIER_DISPATCH_RADIUS_KM=15

# ── Money model ──────────────────────────────────────────────
# Voryn is provider-funded: customers pay no platform fee, and Voryn's revenue
# is the provider commission plus the delivery margin. Per-category commission
# rates live in src/lib/commission.ts; a provider can be given a negotiated
# override via Provider.commissionBps.
# Days a provider's earnings stay pending before they clear to available.
EARNINGS_CLEAR_DAYS=2
# Voryn's share of the customer delivery fee (basis points, 2200 = 22%),
# clamped between the min and max below. The courier is guaranteed the rest,
# plus 100% of tips.
DELIVERY_MARGIN_BPS=2200
DELIVERY_MARGIN_MIN_MINOR=5000
DELIVERY_MARGIN_MAX_MINOR=20000
# Commission taken from a ride fare (basis points). Never applied to tips.
RIDE_COMMISSION_BPS=1200
# Voryn Points redemption is capped per order at 80% of the commission that
# order earns (see src/lib/loyalty.ts), so a discount can never exceed the
# revenue it protects. The rewards fund is a provision that legitimately runs a
# small deficit early on; only a deficit past this tolerance tightens the cap.
REWARDS_FUND_DEFICIT_TOLERANCE_MINOR=5000000

# SMS delivery for OTP codes.
#  dev    = log codes to server output (development only; production refuses to boot)
#  twilio = send real SMS via Twilio (create account at twilio.com, buy a number
#           or messaging service with Jamaica (+1876) capability)
SMS_PROVIDER=dev
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Use ONE of the following: a Messaging Service SID (recommended) or a From number
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM=

# Per-instance Prisma connection pool cap. instances x limit must stay below
# the Postgres plan's max connections (see src/lib/prisma.ts).
DB_CONNECTION_LIMIT=10
